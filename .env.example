# ================================================
# AUTO BASE BRASIL — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# ================================================

# Supabase (https://supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxx
SUPABASE_SERVICE_ROLE_KEY=xxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ================================================
# PROVIDERS DE DADOS VEICULARES
# Preencher após fechar contrato com o fornecedor
# ================================================

# AvaliService — recomendado (leilão + sinistro incluídos)
# Contato: avaliservice.com.br | WhatsApp no site
AVALISERVICE_API_KEY=
AVALISERVICE_BASE_URL=https://api.avaliservice.com.br

# ConsultarPlaca — alternativa
# Contato: docs.consultarplaca.com.br
CONSULTARPLACA_API_KEY=
CONSULTARPLACA_BASE_URL=https://api.consultarplaca.com.br

# ================================================
# PAGAMENTOS — Mercado Pago (Pix)
# https://www.mercadopago.com.br/developers
# ================================================
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_PUBLIC_KEY=

# ================================================
# GRATUITAS — sem configuração necessária
# ================================================
# BrasilAPI   → brasilapi.com.br  (FIPE, CNPJ, CEP, marcas)
# ViaCEP      → viacep.com.br     (CEP)
