{
  "crons": [
    { "path": "/api/cron/inatividade", "schedule": "0 12 * * *" },
    { "path": "/api/cron/cobranca",    "schedule": "0 8 * * *"  },
    { "path": "/api/cron/boas-vindas", "schedule": "0 9 * * *"  },
    { "path": "/api/cron/validade",    "schedule": "0 10 * * *" },
    { "path": "/api/cron/relatorio",   "schedule": "0 8 * * 1"  }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "consultor.autovaleprevencoes.org.br" }],
      "destination": "https://uniavp.autovaleprevencoes.org.br/captacao",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "consultor.autovaleprevencoes.org.br" }],
      "destination": "https://uniavp.autovaleprevencoes.org.br/:path",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "gestor.autovaleprevencoes.org.br" }],
      "destination": "https://uniavp.autovaleprevencoes.org.br/convite/gestor",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "gestor.autovaleprevencoes.org.br" }],
      "destination": "https://uniavp.autovaleprevencoes.org.br/:path",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "adm.autovaleprevencoes.org.br" }],
      "destination": "https://uniavp.autovaleprevencoes.org.br/admin",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "adm.autovaleprevencoes.org.br" }],
      "destination": "https://uniavp.autovaleprevencoes.org.br/:path",
      "permanent": true
    }
  ]
}
